---
import { itinerariesRouteSlug, type Locale } from '../i18n/translations';
import MainLayout from '../layouts/MainLayout.astro';

import type { ItineraryDetail } from './itineraries';
import ItineraryMapExperience from './ItineraryMapExperience';


interface Props {
  locale: Locale;
  itinerary: ItineraryDetail;
}
const { locale, itinerary } = Astro.props;

const localePath = (code: Locale, slug: string) => (code === "en" ? `/${slug}` : `/${code}/${slug}`);
const listPath = localePath(locale, itinerariesRouteSlug[locale]);

const alternates = (["en", "es", "de"] as Locale[]).map((code) => ({
  lang: code,
  href: new URL(localePath(code, itinerariesRouteSlug[code]), Astro.site).toString(),
}));

const copy = {
  en: {
    back: 'Back to itineraries',
    mapEyebrow: 'Route experience',
    mapTitle: 'Explore key points on the route',
    mapIntro: 'Tap the glowing nodes to open a first immersive 360 view of the itinerary.',
    open360: 'Open 360 view',
    close360: 'Close',
    modalHint: 'Drag to look around the panorama.',
  },
  es: {
    back: 'Volver a itinerarios',
    mapEyebrow: 'Experiencia de ruta',
    mapTitle: 'Explora puntos clave del itinerario',
    mapIntro: 'Pulsa los nodos iluminados para abrir una primera vista inmersiva en 360 del itinerario.',
    open360: 'Abrir vista 360',
    close360: 'Cerrar',
    modalHint: 'Arrastra para moverte por la panorámica.',
  },
  de: {
    back: 'Zurück zu den Reisen',
    mapEyebrow: 'Routenerlebnis',
    mapTitle: 'Wichtige Punkte der Route erkunden',
    mapIntro: 'Tippe auf die leuchtenden Marker, um eine erste immersive 360-Ansicht der Route zu öffnen.',
    open360: '360-Ansicht öffnen',
    close360: 'Schließen',
    modalHint: 'Zum Umschauen in der Panoramaansicht ziehen.',
  },
} as const;

const page = copy[locale];
---
<MainLayout
  locale={locale}
  lang={locale}
  title={`${itinerary.title} | SierraWalks`}
  description={itinerary.summary}
  alternates={alternates}
>
  <main class="mx-auto max-w-6xl px-4 pb-16 pt-8 sm:px-6 lg:px-8 lg:pb-24 lg:pt-12">
    <a href={listPath} class="inline-flex rounded-full border border-[#173126]/12 bg-white px-4 py-2 text-sm font-semibold text-[#173126]">
      ← {page.back}
    </a>

    <section class="mt-6 rounded-[2rem] border border-black/5 bg-white/80 p-6 shadow-[0_18px_50px_rgba(23,49,38,0.07)] sm:p-8">
      <p class="text-[0.74rem] font-bold uppercase tracking-[0.14em] text-[#7a5c1a]">{itinerary.area}</p>
      <h1 class="mt-3 text-4xl tracking-[-0.04em] text-[#173126] sm:text-5xl">{itinerary.title}</h1>
      <p class="mt-5 max-w-3xl text-base leading-7 text-[#173126]/75 sm:text-lg">{itinerary.summary}</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {itinerary.highlights.map((tag) => <span class="rounded-full border border-[#173126]/10 bg-[#f8f4ec] px-3 py-1.5 text-sm font-medium text-[#173126]/84">{tag}</span>)}
      </div>
    </section>

    <section class="mt-8">
      <ItineraryMapExperience
        client:only="react"
        itineraryTitle={itinerary.title}
        mapImageSrc={itinerary.mapImageSrc}
        nodes={itinerary.nodes}
        labels={{
          eyebrow: page.mapEyebrow,
          title: page.mapTitle,
          intro: page.mapIntro,
          open360: page.open360,
          close360: page.close360,
          modalHint: page.modalHint,
        }}
      />
    </section>
  </main>
</MainLayout>