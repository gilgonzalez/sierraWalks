---
import DayNightHero from "../../components/home/DayNightHero";
import trailImage from "../../assets/blog-placeholder-5.jpg";
import SierraFeatureCard from "../../components/brand/SierraFeaturedCard.astro";
import SierraImagePanel from "../../components/brand/SierraImagePanel.astro";
import SierraQuotePanel from "../../components/brand/SierraQuotePanel.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { homeCopy, itinerariesRouteSlug, type Locale } from "../../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = homeCopy[locale];

const localePath = (code: Locale) => (code === "en" ? "/" : `/${code}/`);
const itinerariesPath = locale === "en"
  ? `/${itinerariesRouteSlug[locale]}`
  : `/${locale}/${itinerariesRouteSlug[locale]}`;
const alternates = (["en", "es", "de"] as Locale[]).map((code) => ({

  lang: code,
  href: new URL(localePath(code), Astro.site).toString(),
}));

const cardAccents = ["forest", "gold", "moss"] as const;
const homeSections = {
