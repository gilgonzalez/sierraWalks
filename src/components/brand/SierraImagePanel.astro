---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	image: ImageMetadata;
	alt: string;
	eyebrow?: string;
	title?: string;
	caption?: string;
}

const {
	image,
	alt,
	eyebrow,
	title,
	caption,
} = Astro.props;
---

<figure class="sw-image-panel">
	<div class="sw-image-panel__media">
		<Image src={image} alt={alt} />
	</div>

	<figcaption class="sw-image-panel__body">
		{eyebrow && <p class="sw-image-panel__eyebrow">{eyebrow}</p>}
		{title && <h3 class="sw-image-panel__title">{title}</h3>}
		{caption && <p class="sw-image-panel__caption">{caption}</p>}
	</figcaption>
</figure>