const page = copy[locale];
const itineraryRouteMeta = {
  en: {
    "white-villages-grazalema": { steps: ["Ronda", "Zahara", "Grazalema", "Pinsapar"], isCircular: true },
    "alcornocales-historic-paths": { steps: ["Jimena", "Aljibe", "Forest track", "Castellar"], isCircular: false },
    "wildlife-biodiversity-sierras": { steps: ["Visitor centre", "Viewpoint", "Wetland", "Sierra trail"], isCircular: true },
    "strait-atlantic-light": { steps: ["Tarifa", "Clifftop", "Migration point", "Atlantic ridge"], isCircular: false },
  },
  es: {
    "pueblos-blancos-grazalema": { steps: ["Ronda", "Zahara", "Grazalema", "Pinsapar"], isCircular: true },
    "alcornocales-y-caminos-historicos": { steps: ["Jimena", "Aljibe", "Pista forestal", "Castellar"], isCircular: false },
    "biodiversidad-aves-y-sierras": { steps: ["Centro de visitantes", "Mirador", "Humedal", "Senda de sierra"], isCircular: true },
    "estrecho-y-luz-del-atlantico": { steps: ["Tarifa", "Acantilado", "Paso migratorio", "Loma atlántica"], isCircular: false },
  },
  de: {
    "weisse-doerfer-grazalema": { steps: ["Ronda", "Zahara", "Grazalema", "Pinsapar"], isCircular: true },
    "alcornocales-und-historische-wege": { steps: ["Jimena", "Aljibe", "Waldweg", "Castellar"], isCircular: false },
    "artenvielfalt-und-sierras": { steps: ["Besucherzentrum", "Aussichtspunkt", "Feuchtgebiet", "Sierra-Pfad"], isCircular: true },
    "meerenge-und-atlantisches-licht": { steps: ["Tarifa", "Klippe", "Zugroute", "Atlantikrücken"], isCircular: false },
  },
} as const;
const items = page.items.map((item) => {
  const routeMeta = itineraryRouteMeta[locale][item.slug as keyof typeof itineraryRouteMeta[typeof locale]];
  return {
    ...item,
    steps: routeMeta.steps,
    isCircular: routeMeta.isCircular,
  };
});
const formats = [...new Set(items.map((item) => item.format))];
---

<MainLayout
  locale={locale}
  lang={page.lang}
  title={page.title}
  description={page.description}
  alternates={alternates}
>
  <main class="mx-auto max-w-7xl px-4 pb-16 pt-8 sm:px-6 lg:px-8 lg:pb-24 lg:pt-12">
    <section class="rounded-[2rem] border border-black/5 bg-white/65 px-5 py-8 shadow-[0_18px_50px_rgba(23,49,38,0.07)] backdrop-blur-sm sm:px-8 sm:py-10 lg:px-12 lg:py-14">
      <p class="text-[0.75rem] font-extrabold uppercase tracking-[0.18em] text-[#7a5c1a]">{page.eyebrow}</p>
      <div class="mt-3 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-4xl">
          <h1 class="text-4xl tracking-[-0.04em] text-[#173126] sm:text-5xl lg:text-6xl">{page.heading}</h1>
          <p class="mt-5 max-w-3xl text-base leading-7 text-[#173126]/72 sm:text-lg sm:leading-8">{page.intro}</p>
        </div>
        <p class="text-sm font-semibold text-[#173126]/48"><span data-results-count>{items.length}</span> {page.resultsLabel}</p>
      </div>
    </section>

    <section class="mt-6 rounded-[1.5rem] border border-black/5 bg-white/70 p-3 shadow-[0_12px_30px_rgba(23,49,38,0.05)] backdrop-blur-sm sm:p-4">
      <div class="grid gap-3 md:grid-cols-[minmax(0,1.5fr)_minmax(0,0.8fr)_minmax(0,0.8fr)]">
        <input data-filter-search type="search" placeholder={page.searchPlaceholder} class="h-12 rounded-2xl border border-[#173126]/10 bg-white px-4 text-sm text-[#173126] outline-none placeholder:text-[#173126]/38" />
        <select data-filter-format class="h-12 rounded-2xl border border-[#173126]/10 bg-white px-4 text-sm text-[#173126] outline-none">
          <option value="">{page.allFormats}</option>
          {formats.map((format) => <option value={format}>{format}</option>)}
        </select>
        <select data-filter-difficulty class="h-12 rounded-2xl border border-[#173126]/10 bg-white px-4 text-sm text-[#173126] outline-none">
          <option value="">{page.allDifficulties}</option>
          {Object.entries(page.difficulty).map(([value, label]) => <option value={value}>{label}</option>)}
        </select>
      </div>
    </section>

    <section class="mt-10 grid gap-x-5 gap-y-10 lg:mt-12 lg:grid-cols-2 lg:gap-x-6 lg:gap-y-12" data-itineraries-grid>
      {items.map((item) => (
        <ItineraryCard item={item} labels={page} href={getItineraryPath(locale, item.slug)} />
      ))}
    </section>
  </main>

  <script>
    const grid = document.querySelector("[data-itineraries-grid]");
    const cards = Array.from(document.querySelectorAll("[data-itinerary-card]"));
    const search = document.querySelector("[data-filter-search]");
    const format = document.querySelector("[data-filter-format]");
    const difficulty = document.querySelector("[data-filter-difficulty]");
    const count = document.querySelector("[data-results-count]");

    const applyFilters = () => {
      const q = search instanceof HTMLInputElement ? search.value.toLowerCase().trim() : "";
      const f = format instanceof HTMLSelectElement ? format.value : "";
      const d = difficulty instanceof HTMLSelectElement ? difficulty.value : "";
      let visible = 0;
      cards.forEach((card) => {
        if (!(card instanceof HTMLElement)) return;
        const haystack = card.dataset.search ?? "";
        const matchQ = !q || haystack.includes(q);
        const matchF = !f || card.dataset.format === f;
        const matchD = !d || card.dataset.difficulty === d;
        const show = matchQ && matchF && matchD;
        card.style.display = show ? "block" : "none";
        if (show) visible += 1;
      });
      if (count) count.textContent = String(visible);
      if (grid instanceof HTMLElement) grid.dataset.empty = visible === 0 ? "true" : "false";
    };

    [search, format, difficulty].forEach((el) => el?.addEventListener("input", applyFilters));
    applyFilters();
  </script>