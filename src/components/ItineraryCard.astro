---
import imageOne from "../assets/blog-placeholder-1.jpg";
import imageTwo from "../assets/blog-placeholder-4.jpg";
import imageThree from "../assets/blog-placeholder-5.jpg";

type Difficulty = "easy" | "moderate" | "challenging";

interface Itinerary {
  slug: string;
  title: string;
  area: string;
  duration: string;
  difficulty: Difficulty;
  format: string;
  priceFrom: string;
  summary: string;
  highlights: string[];
  season: string;
  steps: string[];
  isCircular: boolean;
}

interface Labels {
  cta: string;
  slugLabel: string;
  metaSeason: string;
  metaPrice: string;
  highlights: string;
  routeLoopTooltip: string;
  routeLinearTooltip: string;
  difficulty: Record<Difficulty, string>;
}

interface Props {
  item: Itinerary;
  labels: Labels;
  href: string;
}

const { item, labels, href } = Astro.props;

const difficultyClassMap = {
  easy: "bg-emerald-500/88 text-white ring-1 ring-white/18",
  moderate: "bg-amber-500/88 text-[#1f1605] ring-1 ring-white/20",
  challenging: "bg-rose-500/88 text-white ring-1 ring-white/18",
} as const;

const searchText = [
  item.title,
  item.area,
  item.summary,
  item.format,
  item.season,
  item.highlights.join(" "),
  labels.difficulty[item.difficulty],
].join(" ").toLowerCase();

const cardImages = [imageOne, imageTwo, imageThree];
const imageIndex = item.slug.length % cardImages.length;
const cardImage = cardImages[imageIndex];
const routeTooltip = item.isCircular ? labels.routeLoopTooltip : labels.routeLinearTooltip;
---

<article
  data-itinerary-card
  data-search={searchText}
  data-format={item.format}
  data-difficulty={item.difficulty}
  class="group overflow-visible rounded-[1.75rem] border border-[#173126]/8 bg-[linear-gradient(180deg,rgba(255,255,255,0.98),rgba(248,244,236,0.94))] shadow-[0_14px_36px_rgba(23,49,38,0.06)] transition-[box-shadow,border-color] duration-300 hover:border-[#173126]/12 hover:shadow-[0_20px_42px_rgba(23,49,38,0.09)]"
>
  <div class="relative aspect-[16/10] overflow-visible rounded-[1.75rem] bg-[#173126]">
    <img
      src={cardImage.src}
      alt={item.title}
      class="h-full w-full object-cover transition-[filter] duration-300 ease-out group-hover:brightness-[1.02]"
    />
    <div class="absolute left-4 top-3 h-16 w-16 rounded-full bg-[#f3d78b]/78 blur-2xl opacity-90 transition-opacity duration-300 ease-out group-hover:opacity-100" />
    <div class="absolute -left-2 -top-3 z-20 max-w-[16.5rem] rounded-[1.35rem] border border-white/18 bg-[linear-gradient(180deg,rgba(255,255,255,0.95),rgba(249,244,233,0.88))] px-4 py-3 shadow-[0_24px_46px_rgba(8,17,27,0.24)] backdrop-blur-md transition-[box-shadow] duration-300 ease-out group-hover:shadow-[0_28px_52px_rgba(8,17,27,0.26)] sm:-left-3 sm:-top-4 sm:max-w-[18rem] sm:px-5 sm:py-4">
      <p class="text-[0.68rem] font-bold uppercase tracking-[0.16em] text-[#7a5c1a]">{item.area}</p>
      <h2 class="mt-2 text-[1.28rem] leading-[0.98] tracking-[-0.04em] text-[#10251c] sm:text-[1.48rem]">{item.title}</h2>
    </div>
    <div class="absolute inset-x-0 bottom-0 p-4 sm:p-5">
      <div class="flex flex-wrap items-center gap-2">
        <span class={`inline-flex rounded-full px-3 py-1 text-[0.72rem] font-bold shadow-[0_8px_20px_rgba(0,0,0,0.16)] ${difficultyClassMap[item.difficulty]}`}>
          {labels.difficulty[item.difficulty]}
        </span>
        <span class="inline-flex rounded-full bg-white/14 px-3 py-1 text-[0.72rem] font-semibold text-white ring-1 ring-white/16 backdrop-blur-sm">
          {item.format}
        </span>
        <span class="inline-flex rounded-full bg-black/28 px-3 py-1 text-[0.72rem] font-semibold text-[#f6e2b8] ring-1 ring-white/10 backdrop-blur-sm">
          {item.duration}
        </span>
        <span class="group/route relative inline-flex">
          <span aria-label={routeTooltip} class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[#f3d78b]/16 text-[#f3d78b] ring-1 ring-[#f3d78b]/24 backdrop-blur-sm">
            {item.isCircular ? (
              <svg aria-hidden="true" viewBox="0 0 16 16" class="h-4 w-4 fill-none stroke-current" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 2.6a5.4 5.4 0 1 0 4.56 2.5" />
                <path d="M10.15 2.85h2.95V5.8" />
                <path d="M13.1 2.9 9.85 6.15" />
              </svg>
            ) : (
              <svg aria-hidden="true" viewBox="0 0 16 16" class="h-4 w-4 fill-none stroke-current" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="3" cy="8" r="1.35" />
                <path d="M5.1 8h5.7" />
                <path d="M9.5 5.8 13 8l-3.5 2.2" />
              </svg>
            )}
          </span>
          <span class="pointer-events-none absolute left-1/2 top-full z-10 mt-2 -translate-x-1/2 rounded-full bg-[#10251c] px-3 py-1 text-[0.68rem] font-semibold text-white opacity-0 shadow-[0_10px_24px_rgba(8,17,27,0.28)] transition-opacity duration-200 group-hover/route:opacity-100 group-focus-within/route:opacity-100 whitespace-nowrap">
            {routeTooltip}
          </span>
        </span>
      </div>
    </div>
  </div>

  <div class="px-4 pb-4 pt-6 sm:px-5 sm:pb-5 sm:pt-7">
    <div class="grid gap-5 lg:grid-cols-[minmax(0,1.2fr)_auto] lg:items-start">

      <div>
        <div class="mb-4 flex items-center gap-2 text-[0.72rem] font-bold uppercase tracking-[0.14em] text-[#173126]/46">
          <span class="inline-block h-px w-6 bg-[#7a5c1a]/45"></span>
          <span>{labels.highlights}</span>
        </div>
        <p class="max-w-[34ch] text-[1rem] leading-7 text-[#173126]/78">{item.summary}</p>

        <div class="mt-5 flex flex-wrap gap-2">
          {item.highlights.slice(0, 3).map((highlight) => (
            <span class="rounded-full border border-[#173126]/8 bg-[#fcfaf6] px-3 py-1.5 text-sm font-medium text-[#173126]/84 shadow-[0_6px_14px_rgba(23,49,38,0.04)]">
              {highlight}
            </span>
          ))}
        </div>
      </div>

      <dl class="grid gap-3 rounded-[1.2rem] border border-[#173126]/6 bg-[#f8f4ec] p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.45)] lg:min-w-[10.5rem]">
        <div>
          <dt class="text-[0.7rem] font-bold uppercase tracking-[0.12em] text-[#173126]/45">{labels.metaSeason}</dt>
          <dd class="mt-1 text-sm font-semibold text-[#10251c]">{item.season}</dd>
        </div>
        <div>
          <dt class="text-[0.7rem] font-bold uppercase tracking-[0.12em] text-[#173126]/45">{labels.metaPrice}</dt>
          <dd class="mt-1 text-sm font-semibold text-[#10251c]">{item.priceFrom}</dd>
        </div>
      </dl>
    </div>

    <div class="mt-6 flex items-center justify-between gap-4 border-t border-[#173126]/8 pt-4">
      <span class="text-sm font-medium text-[#173126]/56">{labels.slugLabel}: `{item.slug}`</span>
      <a
        href={href}
        class="inline-flex items-center gap-2 rounded-full border border-[#10251c]/10 bg-[#f3d78b] px-4 py-2 text-sm font-extrabold text-[#10251c] shadow-[0_10px_22px_rgba(122,92,26,0.18)] transition-all hover:bg-[#ebcb72] hover:text-[#08111b]"
      >
        <span>{labels.cta}</span>
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</article>