  de: {
    heroTitle: "Finde deinen Weg durch Andalusien.",
    heroLead:
      "Geführte und selbstgeführte Reisen durch Sierras, weiße Dörfer und Schutzlandschaften für Reisende, die Schönheit, Tiefe und Ruhe suchen.",
    heroPrimary: "Reisen entdecken",
    heroSecondary: "Formate vergleichen",
    heroNoteEyebrow: "Langsamer reisen, genauer sehen",
    heroNoteTitle: "Routen, die dich wirklich in die Landschaft hineinführen.",
    heroNoteText:
      "Weniger Abhaken, mehr ein Zugang zu Wegen, Dörfern, Wäldern und zur kulturellen Tiefe des Berglands.",
    proof: [
      "25+ Jahre lokale Erfahrung",
      "Geführt & selbstgeführt",
      "Kuratiertes Bergwandern",
    ],
    journeysEyebrow: "Ausgewählte Reisen",
    journeysTitle: "Drei Wege in die Sierra",
    journeysIntro:
      "Beginne mit der Stimmung deiner Reise und finde dann die passende Route.",
    journeys: [
      [
        "Weiße Dörfer und historische Wege",
        "Für Reisende, die Architektur, Dorfleben und langsameres Wandern schätzen.",
      ],
      [
