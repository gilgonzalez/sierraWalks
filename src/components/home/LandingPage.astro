const page = homeSections[locale];
---

<MainLayout
  locale={locale}
  lang={copy.htmlLang}
  title={copy.metaTitle}
  description={copy.metaDescription}
  alternates={alternates}
>
  <main class="landing landing-scroll-root">
    <section id="hero" class="landing-scroll-section landing-scroll-section--hero">
      <DayNightHero
        client:only="react"
        key={locale}
        locale={locale}
        eyebrow={copy.eyebrow}
        title={page.heroTitle}
        lead={page.heroLead}
      />

      <div class="landing-hero-bar">
      <div class="landing-actions">
        <a class="btn-primary" href={itinerariesPath}>{page.heroPrimary}</a>
        <a class="btn-secondary" href="#formats">{page.heroSecondary}</a>
      </div>
      <div class="landing-proof">
        {page.proof.map((item) => <span>{item}</span>)}
      </div>
    </div>
    </section>

    <section id="journeys" class="landing-scroll-section">
      <div class="landing-section-intro">
        <p class="landing-eyebrow">{page.journeysEyebrow}</p><h2>
          {page.journeysTitle}
        </h2><p>{page.journeysIntro}</p>
      </div>
      <div class="landing-grid">
        {
          page.journeys.map(([title, text], index) => (
            <SierraFeatureCard
              title={title}
              text={text}
              badge={`0${index + 1}`}
              accent={cardAccents[index % cardAccents.length]}
            />
          ))
        }
      </div>
    </section>
    <section class="landing-feature landing-scroll-section" id="why-sierra-walks">
      <div class="landing-feature-copy">
        <p class="landing-eyebrow">{copy.why}</p><h2>{page.whyTitle}</h2><p>
          {page.whyText}
        </p>
      </div><ul class="landing-feature-list surface-list">
        {page.whyBullets.map((item) => <li>{item}</li>)}
      </ul>
    </section>
    <section class="landing-showcase landing-scroll-section" id="landscape">
      <SierraQuotePanel
        quote={page.quote}
        source={page.quoteSource}
        context={page.quoteContext}
      /><SierraImagePanel
        image={trailImage}
        alt={page.imageTitle}
        eyebrow={page.imageEyebrow}
        title={page.imageTitle}
        caption={page.imageCaption}
      />
    </section>
    <section id="travellers" class="landing-scroll-section">
      <div class="landing-section-intro">
        <p class="landing-eyebrow">{page.travellersEyebrow}</p><h2>
          {page.travellersTitle}
        </h2><p>{page.travellersIntro}</p>
      </div><div class="landing-grid">
        {
          page.travellers.map(([title, text]) => (
            <article class="surface-card landing-story-card">
              <>
                <h3 class="surface-card__title">{title}</h3>
                <p class="surface-card__text">{text}</p>
              </>
            </article>
          ))
        }
      </div>
    </section>
    <section id="formats" class="landing-scroll-section">
      <div class="landing-section-intro">
        <p class="landing-eyebrow">{page.formatsEyebrow}</p><h2>
          {page.formatsTitle}
        </h2><p>{page.formatsIntro}</p>
      </div><div class="landing-split-grid">
        {
          page.formats.map(([title, items]) => (
            <article class="surface-card landing-story-card">
              <>
                <h3 class="surface-card__title">{title}</h3>
                <ul class="surface-card__list">
                  {items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </>
            </article>
          ))
        }
      </div>
    </section>
    <section id="seasons" class="landing-scroll-section">
      <div class="landing-section-intro">
        <p class="landing-eyebrow">{page.seasonsEyebrow}</p><h2>
          {page.seasonsTitle}
        </h2><p>{page.seasonsIntro}</p>
      </div><div class="landing-grid">
        {
          page.seasons.map(([title, text]) => (
            <article class="surface-card landing-season-card">
              <>
                <h3 class="surface-card__title">{title}</h3>
                <p class="surface-card__text">{text}</p>
              </>
            </article>
          ))
        }
      </div>
    </section>
    <section class="landing-cta landing-scroll-section" id="plan">
      <h2>{page.ctaTitle}</h2><p>{page.ctaText}</p><a
        class="btn-primary"
        href={itinerariesPath}>{page.ctaButton}</a>
    </section>
  </main>

  <style is:global>
    html {
      scroll-behavior: auto;
      scroll-snap-type: y mandatory;
    }

    body {
      scroll-snap-type: y mandatory;
    }

    .landing-scroll-root {
      position: relative;
    }

    .landing-scroll-section {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      scroll-margin-top: 0;
    }

    .landing-scroll-section--hero {
      scroll-margin-top: 0;
    }

    @media (min-width: 960px) {
      .landing-scroll-section {
        min-height: calc(100vh - 88px);
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .landing-scroll-section--hero {
        justify-content: flex-start;
      }

    }

  </style>
</MainLayout>
