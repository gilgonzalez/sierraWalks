---
import { itinerariesRouteSlug, type Locale } from '../i18n/translations';
import ItineraryCard from './ItineraryCard.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { getItineraryPath } from './itineraries';



interface Props {
  locale: Locale;
}

type Difficulty = "easy" | "moderate" | "challenging";

interface Itinerary {
  slug: string;
  title: string;
  area: string;
  duration: string;
  difficulty: Difficulty;
  format: string;
  priceFrom: string;
  summary: string;
  highlights: string[];
  season: string;
  steps?: string[];
  isCircular?: boolean;
}

const { locale } = Astro.props;

const localePath = (code: Locale, slug: string) =>
  code === "en" ? `/${slug}` : `/${code}/${slug}`;

const alternates = (["en", "es", "de"] as Locale[]).map((code) => ({
  lang: code,
  href: new URL(localePath(code, itinerariesRouteSlug[code]), Astro.site).toString(),
}));

