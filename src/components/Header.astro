---
import { SITE_TITLE } from '../consts';
import { itinerariesRouteSlug, type Locale } from '../i18n/translations';

interface SwitcherLink {
	code: string;
	label: string;
	href: string;
}

interface Props {
	locale?: Locale;
	switcherLabel?: string;
	switcherLinks?: SwitcherLink[];
	blogLabel?: string;
	itinerariesLabel?: string;
}

const {
	locale = 'en',
	switcherLabel = 'Language',
	switcherLinks = [
		{ code: 'en', label: 'English', href: '/' },
		{ code: 'es', label: 'Español', href: '/es/' },
		{ code: 'de', label: 'Deutsch', href: '/de/' },
	],
	blogLabel = 'Journal',
	itinerariesLabel = 'Itineraries',
} = Astro.props;

const homeHref = locale === 'en' ? '/' : `/${locale}/`;
const blogHref = '/blog/';
const itinerariesHref = locale === 'en'
	? `/${itinerariesRouteSlug[locale]}`
	: `/${locale}/${itinerariesRouteSlug[locale]}`;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const normalizePath = (path: string) => path.replace(/\/$/, '') || '/';
const isActivePath = (href: string) => {
	const normalizedHref = normalizePath(href);
	return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
};

const localeFlag: Record<string, string> = {
	en: '🇬🇧',
	es: '🇪🇸',
	de: '🇩🇪',
};
---

<header class="site-header">
	<nav class="site-header__nav container-wide">
		<a class="site-brand" href={homeHref}>{SITE_TITLE}</a>
		<div class="site-header__center" role="navigation" aria-label="Primary">
			<div class="site-header__menu">
				<a class:list={["site-nav-link", { 'is-active': isActivePath(itinerariesHref) }]} href={itinerariesHref} aria-current={isActivePath(itinerariesHref) ? 'page' : undefined}>
					<span class="site-nav-link__icon" aria-hidden="true">🗺️</span>
					<span class="site-nav-link__label">{itinerariesLabel}</span>
				</a>
				<a class:list={["site-nav-link", { 'is-active': isActivePath(blogHref) }]} href={blogHref} aria-current={isActivePath(blogHref) ? 'page' : undefined}>
					<span class="site-nav-link__icon" aria-hidden="true">📰</span>
					<span class="site-nav-link__label">{blogLabel}</span>
				</a>
			</div>
		</div>
		<div class="site-header__actions">
			<div class="lang-switcher lang-switcher--desktop" aria-label={switcherLabel}>
				<div class="lang-switcher__track">
					{switcherLinks.map((link) => (
						<a
							href={link.href}
							lang={link.code}
							hreflang={link.code}
							aria-current={link.code === locale ? 'page' : undefined}
							aria-label={`${switcherLabel}: ${link.label}`}
							title={link.label}
							class:list={['lang-switcher__link', { 'is-active': link.code === locale }]}
						>
							<span class="lang-switcher__flag" aria-hidden="true">{localeFlag[link.code] ?? '🌐'}</span>
							<span class="sr-only">{link.label}</span>
						</a>
					))}
				</div>
			</div>
			<details class="site-header__mobile-menu">
				<summary class="site-header__hamburger" aria-label="Menu" title="Menu">
					<span class="site-header__hamburger-line"></span>
					<span class="site-header__hamburger-line"></span>
					<span class="site-header__hamburger-line"></span>
				</summary>
				<div class="site-header__mobile-sheet-backdrop"></div>
				<div class="site-header__mobile-panel" role="navigation" aria-label="Mobile primary">
					<div class="site-header__mobile-panel-head">
						<p class="site-header__mobile-panel-title">Menu</p>
					</div>
					<div class="site-header__mobile-panel-body">
						<a class:list={["site-nav-link", "site-nav-link--mobile", { 'is-active': isActivePath(itinerariesHref) }]} href={itinerariesHref} aria-current={isActivePath(itinerariesHref) ? 'page' : undefined}>
							<span class="site-nav-link__icon" aria-hidden="true">🗺️</span>
							<span class="site-nav-link__label">{itinerariesLabel}</span>
						</a>
						<a class:list={["site-nav-link", "site-nav-link--mobile", { 'is-active': isActivePath(blogHref) }]} href={blogHref} aria-current={isActivePath(blogHref) ? 'page' : undefined}>
							<span class="site-nav-link__icon" aria-hidden="true">📰</span>
							<span class="site-nav-link__label">{blogLabel}</span>
						</a>
					</div>
					<div class="lang-switcher lang-switcher--mobile" aria-label={switcherLabel}>
						<p class="site-header__mobile-panel-label">{switcherLabel}</p>
						<div class="lang-switcher__track">
							{switcherLinks.map((link) => (
								<a
									href={link.href}
									lang={link.code}
									hreflang={link.code}
									aria-current={link.code === locale ? 'page' : undefined}
									aria-label={`${switcherLabel}: ${link.label}`}
									title={link.label}
									class:list={['lang-switcher__link', { 'is-active': link.code === locale }]}
								>
									<span class="lang-switcher__flag" aria-hidden="true">{localeFlag[link.code] ?? '🌐'}</span>
									<span class="sr-only">{link.label}</span>
								</a>
							))}
						</div>
					</div>
				</div>
			</details>
		</div>
	</nav>
</header>
