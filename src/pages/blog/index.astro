---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import MainLayout from '../../layouts/MainLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featuredPost, ...otherPosts] = posts;
const imageTransitionName = (slug: string) => `blog-image-${slug}`;
---

<MainLayout
	locale="en"
	lang="en"
	title="Journal | SierraWalks"
	description="Stories, field notes and walking inspiration from the sierras of Andalucia."
>
	<main class="blog-index container-wide">
		<section class="blog-hero">
			<p class="landing-eyebrow">SierraWalks Journal</p>
			<h1 class="blog-hero__title">Stories, landscapes and walking notes from Andalucia.</h1>
			<p class="blog-hero__lead">A quieter editorial space for routes, local history, protected landscapes and the cultural texture of the sierras.</p>
		</section>

		{featuredPost && (
			<section class="blog-featured">
				<a class="blog-featured__link" href={`/blog/${featuredPost.id}/`}>
					{featuredPost.data.heroImage && (
						<div transition:name={imageTransitionName(featuredPost.id)}>
							<Image src={featuredPost.data.heroImage} alt={featuredPost.data.title} width={1400} height={800} />
						</div>
					)}
					<div class="blog-featured__body">
						<p class="blog-kicker">Featured article</p>
						<h2>{featuredPost.data.title}</h2>
						<p>{featuredPost.data.description}</p>
						<span class="blog-date"><FormattedDate date={featuredPost.data.pubDate} /></span>
					</div>
				</a>
			</section>
		)}

		<section class="blog-grid">
			{otherPosts.map((post) => (
				<article class="blog-card">
					<a class="blog-card__link" href={`/blog/${post.id}/`}>
						{post.data.heroImage && (
							<div transition:name={imageTransitionName(post.id)}>
								<Image src={post.data.heroImage} alt={post.data.title} width={720} height={480} />
							</div>
						)}
						<p class="blog-kicker">Journal</p>
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
						<span class="blog-date"><FormattedDate date={post.data.pubDate} /></span>
					</a>
				</article>
			))}
		</section>
	</main>
</MainLayout>
