---
import { SITE_TITLE } from '../consts';
import { itinerariesRouteSlug } from '../i18n/translations';

interface SwitcherLink {
	code: string;
	label: string;
	href: string;
}

interface Props {
	locale?: string;
	switcherLabel?: string;
	switcherLinks?: SwitcherLink[];
	blogLabel?: string;
	itinerariesLabel?: string;
}

const {
	locale = 'en',
	switcherLabel = 'Language',
	switcherLinks = [
		{ code: 'en', label: 'English', href: '/' },
		{ code: 'es', label: 'Español', href: '/es/' },
		{ code: 'de', label: 'Deutsch', href: '/de/' },
	],
	blogLabel = 'Journal',
	itinerariesLabel = 'Itineraries',
} = Astro.props;

const homeHref = locale === 'en' ? '/' : `/${locale}/`;
const blogHref = '/blog/';
const itinerariesHref = locale === 'en'
	? `/${itinerariesRouteSlug[locale]}`
	: `/${locale}/${itinerariesRouteSlug[locale]}`;
---

<header class="site-header">
	<nav class="site-header__nav container-wide">
		<a class="site-brand" href={homeHref}>{SITE_TITLE}</a>
		<div class="site-header__actions">
			<a class="site-nav-link" href={itinerariesHref}>{itinerariesLabel}</a>
			<a class="site-nav-link" href={blogHref}>{blogLabel}</a>
			<div class="lang-switcher" aria-label={switcherLabel}>
				<div class="lang-switcher__track">
					{switcherLinks.map((link) => (
						<a
							href={link.href}
							lang={link.code}
							hreflang={link.code}
							aria-current={link.code === locale ? 'page' : undefined}
							class:list={['lang-switcher__link', { 'is-active': link.code === locale }]}
						>
							<span class="lang-switcher__code" aria-hidden="true">{link.code.toUpperCase()}</span>
							<span class="lang-switcher__text">{link.label}</span>
						</a>
					))}
				</div>
			</div>
		</div>
	</nav>
</header>
